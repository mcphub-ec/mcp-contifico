# ─── Contifico MCP Server ──────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# API Key proporcionada por Contifico (sección Integraciones del panel).
CONTIFICO_API_KEY=

# Token del Punto de Venta (POS). Requerido para crear/modificar documentos.
CONTIFICO_POS_TOKEN=

# (Opcional) URL base de la API. No modificar salvo indicación de Contifico.
# CONTIFICO_BASE_URL=https://api.contifico.com/sistema

# (Opcional) Timeout HTTP en segundos.
# CONTIFICO_HTTP_TIMEOUT=30

# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse
MCP_PORT=8000
